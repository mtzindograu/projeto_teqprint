# ===========================================
# CONFIGURAÇÃO DO AMBIENTE - TEQ PRINT
# Copie este arquivo para .env.local
# ===========================================

# -------------------------------------------
# SENHA DO ADMINISTRADOR
# Alterar em produção para uma senha segura
# -------------------------------------------
ADMIN_PASSWORD=teqprint2024

# -------------------------------------------
# CONFIGURAÇÃO DO SUPABASE
# Obtenha estas chaves em:
# https://supabase.com/dashboard/project/_/settings/api
# -------------------------------------------

# URL do projeto (ex: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave anon/public (chave longa que começa com eyJhbG...)
# ESTA CHAVE É SEGURA PARA USO NO FRONTEND
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA-CHAVE-ANONIMA-AQUI

# -------------------------------------------
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.local
# 2. Substitua os valores pelas suas chaves reais
# 3. Reinicie o servidor: npm run dev
# -------------------------------------------
